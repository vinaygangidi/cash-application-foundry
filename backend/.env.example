# Azure AI Foundry Project connection string
# Format: <HostName>;<SubscriptionId>;<ResourceGroup>;<ProjectName>
# Find in: AI Foundry portal → your project → Overview → "Project connection string"
AIPROJECT_CONNECTION_STRING=<your-host>.api.azureml.ms;<subscription-id>;<resource-group>;<project-name>

# Model deployment name in your AI Foundry project
# Create in: AI Foundry portal → Deployments → Deploy a model
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Set to "true" to use fixture data without Azure credentials
USE_FIXTURES=true
