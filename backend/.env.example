# Azure AI Foundry Project connection string
# Format: <HostName>;<SubscriptionId>;<ResourceGroup>;<ProjectName>
# Find in: AI Foundry portal → your project → Overview → "Project connection string"
AIPROJECT_CONNECTION_STRING=<your-host>.api.azureml.ms;<subscription-id>;<resource-group>;<project-name>

# Per-agent model routing — each agent uses the right model for its cognitive task
MODEL_BANK_AGENT=gpt-5.4-mini        # Fast extraction — newest mini model
MODEL_AR_AGENT=gpt-5.4-mini          # Fast index building — newest mini model
MODEL_RECON_AGENT=gpt-4o             # CodeInterpreterTool + complex matching
MODEL_REASONING_AGENT=gpt-5          # Flagship model for exception reasoning judgment
MODEL_POSTING_AGENT=gpt-4o           # Complex GL rules + workqueue generation

# Set to "true" to use fixture data without Azure credentials (demo/hackathon mode)
USE_FIXTURES=true
